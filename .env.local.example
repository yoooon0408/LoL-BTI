# Google Gemini API 키
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=여기에키입력

# Google AdSense (선택 사항 — 없으면 광고 플레이스홀더만 표시됨)
# https://adsense.google.com/ 에서 발급
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_AD_SLOT_TOP=xxxxxxxxxx
NEXT_PUBLIC_AD_SLOT_LEFT=xxxxxxxxxx
NEXT_PUBLIC_AD_SLOT_RIGHT=xxxxxxxxxx
